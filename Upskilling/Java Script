<!DOCTYPE html>
<html>
<head>
    <title>Addition Program</title>
</head>
<body>
    <script>
        let a = 10;
        let b = 20;
        let sum = a + b;
        document.write("Sum = " + sum);
    </script>
</body>
</html>
