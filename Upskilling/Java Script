<!DOCTYPE html>
<html>
<head>
    <title>Even or Odd</title>
</head>
<body>
    <script>
        let num = 8;

        if (num % 2 == 0)
            document.write(num + " is Even");
        else
            document.write(num + " is Odd");
    </script>
</body>
</html>
