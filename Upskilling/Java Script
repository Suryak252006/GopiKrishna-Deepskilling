<!DOCTYPE html>
<html>
<head>
    <title>Change Text</title>
</head>
<body>
    <h1 id="msg">Hello</h1>
    <button onclick="changeText()">Change</button>

    <script>
        function changeText() {
            document.getElementById("msg").innerHTML = "Welcome to JavaScript";
        }
    </script>
</body>
</html>
