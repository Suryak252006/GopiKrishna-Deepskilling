<!DOCTYPE html>
<html>
<head>
    <title>JavaScript Alert</title>
</head>
<body>
    <button onclick="showMessage()">Click Me</button>

    <script>
        function showMessage() {
            alert("Welcome to JavaScript!");
        }
    </script>
</body>
